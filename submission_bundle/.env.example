# Kaggle Benchmarks local development
# According to the current kaggle-benchmarks docs, local development uses
# a Kaggle Model Proxy token rather than direct OpenAI/Anthropic SDK auth.

MODEL_PROXY_URL=https://mp-staging.kaggle.net/models/openapi
MODEL_PROXY_API_KEY=replace-with-your-kaggle-model-proxy-token

# Defaults used by kaggle-benchmarks
LLM_DEFAULT=google/gemini-2.5-flash
LLM_DEFAULT_EVAL=openai/gpt-4o
LLMS_AVAILABLE=google/gemini-2.5-flash,google/gemini-2.5-pro,openai/gpt-4o,anthropic/claude-sonnet-4

# Repo-level defaults
KBENCH_TRACK=attention
KBENCH_PROJECT_SLUG=my-kaggle-agi-benchmark
KBENCH_LIVE_MODELS=google/gemini-2.5-flash,openai/gpt-4o
KBENCH_LIVE_TASK=
KBENCH_LIVE_DATASET=
KBENCH_OUTPUT_DIR=outputs

# Optional Kaggle CLI auth for upload / resource management convenience
KAGGLE_USERNAME=
KAGGLE_KEY=

# Optional direct provider keys for side experiments outside kaggle-benchmarks
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
